# Servidor
NODE_ENV=development
PORT=3333

# Banco de dados (Postgres local via Docker Compose)
DATABASE_URL="postgresql://recampus:recampus@localhost:5432/recampus?schema=public"

# JWT
JWT_SECRET="troque-por-um-segredo-forte-gerado-com-openssl-rand-hex-32"
JWT_EXPIRES_IN="15m"
REFRESH_TOKEN_SECRET="troque-por-outro-segredo-forte-diferente-do-jwt-secret"
REFRESH_TOKEN_EXPIRES_IN="7d"

# CORS - origem exata do frontend (nunca usar * quando cookies sao enviados)
CORS_ORIGIN="http://localhost:5173"

# Rate limit (janela em ms e numero maximo de requisicoes)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10
