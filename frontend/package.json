{
  "name": "@recampus/frontend",
  "private": true,
  "version": "0.1.0",
  "description": "Landing page + PWA do ReCampus - Marketplace de Economia Circular Universitaria",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
